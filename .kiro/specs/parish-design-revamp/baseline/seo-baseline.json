{
  "_meta": {
    "purpose": "Pre-revamp SEO baseline for byte-for-byte comparison in Phase 5 (task 5.3). Captures the route set, slugs, usePageSEO inputs, page-level JSON-LD payloads, the global JsonLdSchema payload, and sitemap entries as they exist BEFORE any revamp code change.",
    "capturedBy": "Task 0.1 — Capture the pre-revamp baseline",
    "gitCommit": "c02d6d33",
    "gitBranch": "main",
    "validatesRequirements": ["6.7", "5.4"],
    "constants": {
      "SITE_NAME": "Greenacres Walkerville Catholic Parish",
      "BASE_URL_usePageSEO": "https://www.gwparish.org.au",
      "DEFAULT_OG_IMAGE": "/assets/source/hero_3.webp",
      "titleRule": "fullTitle = (title === SITE_NAME) ? title : `${title} | ${SITE_NAME}`",
      "ogImageRule": "imageUrl = BASE_URL + (ogImage || DEFAULT_OG_IMAGE)"
    }
  },

  "routeManifest": {
    "_source": "src/lib/routes.ts (PATHS + ROUTE_MANIFEST)",
    "paths": {
      "HOME": "/",
      "MASS_TIMES": "/mass-times",
      "CONTACT": "/contact",
      "ABOUT": "/about",
      "HISTORY": "/history",
      "NEW_HERE": "/new-here",
      "NEWS_EVENTS": "/news-events",
      "VOLUNTEER": "/volunteer",
      "GALLERY": "/gallery",
      "DAILY_READINGS": "/daily-readings",
      "BULLETIN": "/news-events/bulletin/:id"
    },
    "manifestOrder": [
      { "path": "/", "label": "Home", "section": "Worship" },
      { "path": "/mass-times", "label": "Mass Times", "section": "Worship" },
      { "path": "/daily-readings", "label": "Readings & Reflection", "section": "Worship" },
      { "path": "/news-events", "label": "News & Events", "section": "Worship" },
      { "path": "/about", "label": "About Us", "section": "Explore" },
      { "path": "/history", "label": "History", "section": "Explore" },
      { "path": "/new-here", "label": "I'm New Here", "section": "Explore" },
      { "path": "/gallery", "label": "Gallery", "section": "Explore" },
      { "path": "/volunteer", "label": "Volunteer", "section": "Community" },
      { "path": "/contact", "label": "Contact", "section": "Community" }
    ],
    "allStaticPaths": [
      "/", "/mass-times", "/daily-readings", "/news-events",
      "/about", "/history", "/new-here", "/gallery", "/volunteer", "/contact"
    ],
    "routerConfig": {
      "_source": "src/App.tsx createBrowserRouter",
      "rootPath": "/",
      "rootElement": "RootLayout",
      "children": [
        { "index": true, "element": "HomePage" },
        { "path": "mass-times", "element": "MassTimesPage" },
        { "path": "contact", "element": "ContactPage" },
        { "path": "about", "element": "AboutPage" },
        { "path": "history", "element": "HistoryPage" },
        { "path": "new-here", "element": "NewHerePage" },
        { "path": "news-events", "element": "NewsEventsPage" },
        { "path": "news-events/bulletin/:id", "element": "BulletinPage" },
        { "path": "volunteer", "element": "VolunteerPage" },
        { "path": "gallery", "element": "GalleryPage" },
        { "path": "daily-readings", "element": "DailyReadingsPage" },
        { "path": "*", "element": "NotFoundPage" }
      ]
    }
  },

  "usePageSEO": {
    "_note": "Exact inputs passed to usePageSEO() at each call site. path defaults to '/' when omitted; ogImage defaults to DEFAULT_OG_IMAGE when omitted.",
    "HomePage": {
      "title": "Home",
      "description": "Greenacres Walkerville Catholic Parish — Mass times, parish bulletin, sacraments, and community life at St Monica's Walkerville and St Martin's Greenacres in Adelaide.",
      "path": "/"
    },
    "MassTimesPage": {
      "title": "Mass Times",
      "description": "Weekend and weekday Mass schedule for St Monica's Walkerville and St Martin's Greenacres, plus sacrament and reconciliation information.",
      "path": "/mass-times",
      "ogImage": "/assets/refurbishment/st_monica_4.webp"
    },
