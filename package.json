{
  "name": "gw-parish-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:live": "PLAYWRIGHT_BASE_URL=${PLAYWRIGHT_BASE_URL:-https://www.gwparish.org.au} PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "typecheck": "tsc -b",
    "test:coverage": "vitest run --coverage",
    "verify:release": "npm run lint && npm run typecheck && npm test && npm run test:e2e && npm run build",
    "verify:lighthouse:live": "node scripts/run-live-lighthouse.mjs",
    "verify:release:live": "npm run test:e2e:live && npm run verify:lighthouse:live"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/speed-insights": "^1.3.1",
    "framer-motion": "^11.9.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.14",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.7.0",
    "vite": "^5.4.8",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
